# ========================
# Server
# ========================
PORT=5000
NODE_ENV=development

# ========================
# PostgreSQL Database
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medireach
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ========================
# JWT Secrets
# ========================
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_for_access
JWT_REFRESH_SECRET=change_me_to_a_long_random_string_for_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========================
# Password Reset
# ========================
PASSWORD_RESET_SECRET=change_me_to_a_long_random_string_for_reset
PASSWORD_RESET_EXPIRES_IN=1h

# ========================
# Frontend URL (for CORS & reset links)
# ========================
CLIENT_URL=http://localhost:5173

# ========================
# Email (SMTP) — for password reset
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM="MediReach <noreply@medireach.com>"
